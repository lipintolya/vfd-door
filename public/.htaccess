# Запрет просмотра содержимого папок
Options -Indexes

# Включить RewriteEngine
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Принудительный редирект на HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Принудительный редирект на www (или без www - выберите один вариант)
  # Вариант 1: с www
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]
  
  # Вариант 2: без www (раскомментируйте если нужно)
  # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # Если запрашивается index.html — ничего не делаем
  RewriteRule ^index\.html$ - [L]

  # Перенаправлять все запросы на index.html (для Vue Router)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]

  # Перенаправлять /api/* на PHP (если нужно)
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^api/(.*)$ /submit-contact.php [L,QSA]
</IfModule>

# Защитить файлы
<FilesMatch "\.(env|json|md)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Кэширование статики
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Сжатие Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json image/svg+xml
</IfModule>

# CORS для изображений
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico)$">
    Header set Access-Control-Allow-Origin "*"
    Header set Cross-Origin-Resource-Policy "cross-origin"
  </FilesMatch>
  
  # Безопасность
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
