---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { portfolioWorks } from '../data/portfolio';
---

<BaseLayout
  title="Портфолио работ — VFD Doors Челябинск"
  description="Фотографии установок дверей VFD в Челябинске. Реальные объекты наших клиентов."
>
  <Fragment slot="header"><Header /></Fragment>

  <div class="max-w-7xl mx-auto px-4 py-12 sm:py-16">
    <nav class="mb-6 text-sm text-zinc-500">
      <a href="/" class="hover:text-zinc-900">Главная</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-900">Портфолио</span>
    </nav>

    <h1 class="text-2xl sm:text-3xl font-bold text-zinc-900 mb-6 sm:mb-8">Портфолио</h1>

    <div class="space-y-8 sm:space-y-12">
      {portfolioWorks.map(work => (
        <article class="bg-white rounded-2xl border border-zinc-200 overflow-hidden">
          <div class="p-4 sm:p-6">
            <h2 class="text-lg sm:text-xl font-semibold text-zinc-900 mb-2">{work.title}</h2>
            <p class="text-sm text-zinc-500 mb-1">{work.location} • {new Date(work.date).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
            <p class="text-sm text-zinc-600">{work.description}</p>
            {work.series && <span class="inline-block mt-2 px-2.5 py-1 text-xs font-semibold rounded-full bg-teal-50 text-teal-600">{work.series}</span>}
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-1.5 px-4 sm:px-6 pb-4 sm:pb-6">
            {work.images.slice(0, 8).map((img, i) => (
              <div class="aspect-square bg-zinc-50 rounded-lg overflow-hidden">
                <img src={img} alt={`${work.title} — фото ${i + 1}`} class="w-full h-full object-cover" loading="lazy" />
              </div>
            ))}
          </div>
          {work.images.length > 8 && (
            <div class="px-4 sm:px-6 pb-4 sm:pb-6 text-sm text-zinc-500">Ещё {work.images.length - 8} фото...</div>
          )}
        </article>
      ))}
    </div>
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
