---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import doors from '../data/doors.json';

const seriesList = [...new Set(doors.map(d => d.series))].sort();
const coverList = [...new Set(doors.map(d => d.cover))].sort();

const series = Astro.url.searchParams.get('series') || '';
const cover = Astro.url.searchParams.get('cover') || '';
const inStock = Astro.url.searchParams.get('inStock') === 'true';
const sort = Astro.url.searchParams.get('sort') || 'priority';

let filtered = [...doors];

if (series) filtered = filtered.filter(d => d.series === series);
if (cover) filtered = filtered.filter(d => d.cover === cover);
if (inStock) filtered = filtered.filter(d => d.tags?.includes('в наличии'));

const seriesPriority: Record<string, number> = {
  'Эмалекс': 1, 'Иннова': 2, 'Классик Арт': 3,
  'Атум': 4, 'Атум Про': 5, 'Урбан': 6, 'Бэйзик': 7,
};

if (sort === 'priority') {
  filtered.sort((a, b) => {
    const aStock = a.tags?.includes('в наличии') ? 0 : 1;
    const bStock = b.tags?.includes('в наличии') ? 0 : 1;
    const aP = seriesPriority[a.series] ?? 99;
    const bP = seriesPriority[b.series] ?? 99;
    if (aP === 1 && aStock === 0 && bP !== 1) return -1;
    if (bP === 1 && bStock === 0 && aP !== 1) return 1;
    if (aP === 1 && bP === 1) return aStock - bStock || (a.price ?? 0) - (b.price ?? 0);
    return aP - bP || (a.price ?? 0) - (b.price ?? 0);
  });
} else if (sort === 'price-asc') {
  filtered.sort((a, b) => (a.price ?? 0) - (b.price ?? 0));
} else if (sort === 'price-desc') {
  filtered.sort((a, b) => (b.price ?? 0) - (a.price ?? 0));
} else if (sort === 'name-asc') {
  filtered.sort((a, b) => a.name.localeCompare(b.name));
}

const itemsPerPage = 21;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));
const totalPages = Math.ceil(filtered.length / itemsPerPage);
const paginated = filtered.slice((page - 1) * itemsPerPage, page * itemsPerPage);

const title = series ? `Коллекция «${series}»` : 'Каталог дверей';
const description = series
  ? `Межкомнатные двери серии ${series} в Челябинске. Цены от производителя, замер, доставка, монтаж.`
  : 'Каталог межкомнатных и входных дверей VFD в Челябинске. Более 170 моделей от 4 490 ₽.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="header"><Header /></Fragment>

  <div class="max-w-7xl mx-auto px-4 pt-8 sm:pt-12 lg:pt-16 pb-12 sm:pb-16">
    <!-- Breadcrumbs -->
    <nav class="mb-4 sm:mb-6 text-sm text-zinc-500">
      <a href="/" class="hover:text-zinc-900">Главная</a>
      <span class="mx-2">/</span>
      {series ? (
        <><a href="/catalog" class="hover:text-zinc-900">Каталог</a><span class="mx-2">/</span><span class="text-zinc-900">{series}</span></>
      ) : <span class="text-zinc-900">Каталог</span>}
    </nav>

    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <div class="flex items-center justify-between flex-wrap gap-3 mb-4 sm:mb-6">
        <div>
          <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold text-zinc-900">
            {series ? `Коллекция «${series}»` : 'Межкомнатные двери'}
          </h1>
          <p class="text-sm text-zinc-500 mt-1">Найдено: <span class="font-semibold text-zinc-900">{filtered.length}</span> товаров</p>
        </div>
      </div>

      <!-- Filters -->
      <div class="flex flex-wrap gap-2 items-center">
        <a href="/catalog" class="px-3 py-2 rounded-lg text-sm font-medium {series === '' && cover === '' ? 'bg-teal-600 text-white' : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200'}">Все</a>
        {seriesList.map(s => (
          <a href={`/catalog?series=${encodeURIComponent(s)}`} class="px-3 py-2 rounded-lg text-sm font-medium {series === s ? 'bg-teal-600 text-white' : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200'}">{s}</a>
        ))}
      </div>

      <!-- Sort + Stock -->
      <div class="flex flex-wrap gap-2 mt-4 items-center">
        {[
          { value: 'priority', label: '⭐ По популярности' },
          { value: 'price-asc', label: '₽ возр.' },
          { value: 'price-desc', label: '₽ убыв.' },
          { value: 'name-asc', label: 'А-Я' },
        ].map(opt => (
          <a
            href={`?${new URLSearchParams({ ...(series && { series }), ...(cover && { cover }), ...(inStock && { inStock: 'true' }), sort: opt.value }).toString()}`}
            class="px-3 py-2 rounded-lg text-sm font-medium {sort === opt.value ? 'bg-teal-600 text-white' : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200'}"
          >
            {opt.label}
          </a>
        ))}
        <a
          href={`?${new URLSearchParams({ ...(series && { series }), ...(cover && { cover }), inStock: String(!inStock), sort }).toString()}`}
          class="px-3 py-2 rounded-lg text-sm font-medium {inStock ? 'bg-green-600 text-white' : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200'}"
        >
          {inStock ? '✓ В наличии' : 'В наличии'}
        </a>
      </div>
    </div>

    <!-- Products Grid -->
    {paginated.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-5">
        {paginated.map(door => (
          <a
            href={`/catalog/${encodeURIComponent(door.cover)}/${encodeURIComponent(door.series)}/${door.id}`}
            class="group block bg-white rounded-2xl overflow-hidden shadow-sm ring-1 ring-zinc-900/5 hover:shadow-lg hover:ring-zinc-900/10 transition-all"
          >
            <div class="relative w-full aspect-[4/5] bg-zinc-50 overflow-hidden">
              <img
                src={door.colors?.[0]?.image || ''}
                alt={door.name}
                class="w-full h-full object-contain p-3 sm:p-5 transition-transform group-hover:scale-105"
                loading="lazy"
              />
              <!-- Tags -->
              <div class="absolute top-2 left-2 flex flex-wrap gap-1">
                <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-teal-600 text-white">{door.series}</span>
                {door.tags?.filter(t => t !== 'в наличии').slice(0, 2).map(tag => (
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-zinc-100 text-zinc-700">{tag}</span>
                ))}
              </div>
            </div>
            <div class="p-3 sm:p-4">
              <div class="font-semibold text-zinc-900 text-sm leading-snug line-clamp-2 min-h-[2.5rem]">{door.name}</div>
              <div class="mt-1.5 text-sm font-bold text-zinc-900">{door.price.toLocaleString('ru-RU')} <span class="text-xs font-normal text-zinc-500">за полотно</span></div>
              {door.colors?.[0] && (
                <div class="mt-2 flex items-center gap-1.5">
                  <span class="w-3.5 h-3.5 rounded-full inline-block" style={`background-color:${door.colors[0].hex}`}></span>
                  <span class="text-xs text-zinc-500">{door.colors[0].name}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-4xl mb-4">🚪</div>
        <h3 class="text-lg font-semibold text-zinc-900 mb-2">Ничего не найдено</h3>
        <p class="text-sm text-zinc-500 mb-4">Попробуйте изменить параметры фильтрации</p>
        <a href="/catalog" class="inline-flex px-5 py-2.5 rounded-lg bg-teal-600 text-white font-medium text-sm hover:bg-teal-700 transition-colors">Сбросить фильтры</a>
      </div>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="mt-8 sm:mt-10 flex items-center justify-center gap-1.5 flex-wrap">
        {page > 1 && (
          <a href={`?${new URLSearchParams({ ...(series && { series }), ...(cover && { cover }), ...(inStock && { inStock: 'true' }), sort, page: String(page - 1) }).toString()}`}
            class="w-10 h-10 flex items-center justify-center rounded-lg border border-zinc-300 text-zinc-700 hover:bg-zinc-50 transition-colors">←</a>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
          <a href={`?${new URLSearchParams({ ...(series && { series }), ...(cover && { cover }), ...(inStock && { inStock: 'true' }), sort, page: String(p) }).toString()}`}
            class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-semibold transition-colors ${p === page ? 'bg-teal-600 text-white' : 'border border-zinc-300 text-zinc-700 hover:bg-zinc-50'}`}>
            {p}
          </a>
        ))}
        {page < totalPages && (
          <a href={`?${new URLSearchParams({ ...(series && { series }), ...(cover && { cover }), ...(inStock && { inStock: 'true' }), sort, page: String(page + 1) }).toString()}`}
            class="w-10 h-10 flex items-center justify-center rounded-lg border border-zinc-300 text-zinc-700 hover:bg-zinc-50 transition-colors">→</a>
        )}
      </div>
    )}
  </div>

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
